# ==========================================================================
#  Chatbot UI — Environment configuration
# ==========================================================================
#  Copy this file to `.env` and fill in the values for YOUR backend.
#  All variables are OPTIONAL — the app runs out of the box with a built-in
#  mock backend so you can see the UI immediately.
#
#  Only variables prefixed with `VITE_` are exposed to the browser (Vite rule).
#  Never put secrets (private API keys) here — this bundle ships to the client.
# ==========================================================================

# ---------------------------------------------------------------------------
# Backend selection
# ---------------------------------------------------------------------------
# Which chat backend the app talks to.
#   "mock" -> in-memory fake backend with simulated streaming (default)
#   "http" -> your real backend via the HTTP adapter (src/api/httpChatService.ts)
VITE_CHAT_BACKEND=mock

# ---------------------------------------------------------------------------
# HTTP adapter settings (only used when VITE_CHAT_BACKEND=http)
# ---------------------------------------------------------------------------
# Base URL of your API. The HTTP adapter appends the paths defined in
# src/api/endpoints.ts — CHANGE THOSE PATHS TO MATCH YOUR API, they are only
# sensible placeholders and are NOT prescriptive.
VITE_API_BASE_URL=http://localhost:8000

# Optional bearer token sent as `Authorization: Bearer <token>`.
# For real auth, replace this with your own token flow (see src/api/httpChatService.ts).
VITE_API_TOKEN=

# Whether the assistant response should be streamed (Server-Sent Events / chunked).
#   "true"  -> adapter reads a streaming response body token-by-token
#   "false" -> adapter awaits one full JSON response
VITE_ENABLE_STREAMING=true
